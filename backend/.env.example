# Copia este archivo como .env y completa los valores
# NUNCA commitees el archivo .env real

DB_SERVER=localhost
DB_DATABASE=ReservaHotelera
DB_USER=sa
DB_PASSWORD=
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# Genera un valor aleatorio seguro: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=

PORT=5000
NODE_ENV=development

# Frontend URL para CORS (separar por comas si hay varios)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
